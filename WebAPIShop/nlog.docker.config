<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="/app/logs/internal-nlog.txt">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    <!-- Write structured JSON logs to a file inside the container -->
    <target xsi:type="File"
            name="logfile"
            fileName="${environment:NLOG_LOG_DIRECTORY}/api-${shortdate}.json"
            archiveEvery="Day"
            maxArchiveFiles="7">
      <layout xsi:type="JsonLayout">
        <attribute name="timestamp"  layout="${longdate}" />
        <attribute name="level"      layout="${level}" />
        <attribute name="message"    layout="${message}" />
        <attribute name="logger"     layout="${logger}" />
        <attribute name="exception"  layout="${exception:format=tostring}" />
      </layout>
    </target>

    <!-- Also write to stdout so Docker/container logs capture everything -->
    <target xsi:type="Console"
            name="console">
      <layout xsi:type="JsonLayout">
        <attribute name="timestamp"  layout="${longdate}" />
        <attribute name="level"      layout="${level}" />
        <attribute name="message"    layout="${message}" />
        <attribute name="exception"  layout="${exception:format=tostring}" />
      </layout>
    </target>
  </targets>

  <rules>
    <!-- Suppress noisy Microsoft framework logs -->
    <logger name="Microsoft.*"      maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <logger name="*" minlevel="Info"  writeTo="logfile" />
    <logger name="*" minlevel="Info"  writeTo="console" />
  </rules>

</nlog>
